<?xml version="1.0" encoding="UTF-8"?><xsl:stylesheet version="3.0" xmlns:xsl="http://www.w3.org/1999/XSL/Transform" xmlns:xs="http://www.w3.org/2001/XMLSchema" xmlns:map="http://www.w3.org/2005/xpath-functions/map" xmlns:array="http://www.w3.org/2005/xpath-functions/array" xmlns:fn="http://www.w3.org/2005/xpath-functions" xmlns:saxon="http://saxon.sf.net/" xmlns:ny="https://soap.api.nav.gov.hu/external/webnyk/nyomtatvanyinfo/1.0" xmlns:util="urn:util" exclude-result-prefixes="xs map array fn saxon ny util" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance">	<xsl:output method="xml" indent="yes"/>	<xsl:strip-space elements="*"/>	<!-- Paraméterek -->	<xsl:param name="form-name" as="xs:string" select="''"/>	<xsl:param name="form-version" as="xs:string" select="''"/>	<xsl:param name="rules-file" as="xs:string" select="ABCD"/>	<!-- Változók -->	<xsl:variable name="form-xml-tag-name" as="xs:string" select="concat('Form_', $form-name)"/>	<xsl:variable name="type-field" as="xs:string" select="'FIELD'"/>	<xsl:variable name="type-form" as="xs:string" select="'FORM'"/>	<xsl:variable name="event-check" as="xs:string" select="'VALIDITY_RULE'"/>	<xsl:variable name="event-valuecalc-check" as="xs:string" select="'VALUECALC_VALIDITY_RULE'"/>	<xsl:variable name="severity-map" as="map(xs:string, xs:integer)" select="map{ 'WARNING':1, 'ERROR':2, 'CRITICAL':3 }"/>	<xsl:variable name="elements" select="document($rules-file)/DocumentRules/Form/Elem"/>	<!-- error-writer -->	<xsl:template name="error-writer">		<xsl:param name="errorMap" as="map(*)"/>		<Hiba kod="{$errorMap?errorCode}" hibaszoveg="{$errorMap?message}" szint="{$severity-map($errorMap?severity)}" dinamikusLapIndex="{$errorMap?index}" elem="{$errorMap?fieldId}" ruleId="{$errorMap?ruleId}" path="{$errorMap?path}"/>	</xsl:template>	<!-- result típus konverzió-->	<xsl:function name="util:as-maps" as="map(*)*">		<xsl:param name="input" as="item()*"/>		<xsl:sequence select="		if ($input instance of map(*)) then ($input)		else if (every $i in $input satisfies $i instance of map(*)) then $input		else ()	  "/>	</xsl:function>	<!-- Általános rule check -->	<xsl:template name="run-rule-check">		<xsl:param name="raw" as="item()"/>		<xsl:param name="ruleId" as="xs:string"/>		<xsl:param name="context" as="node()"/>		<xsl:variable name="expr" select="replace(string($raw), '\s+$', '')"/>		<xsl:variable name="result" as="item()*">			<xsl:try>				<xsl:evaluate xpath="$expr" context-item="$context"/>				<xsl:catch>					<xsl:sequence select="                    map{                        'errorCode' : 'EVAL_ERROR',                        'message'   : concat('Hibás XPath: ', $expr),                        'severity'  : 'CRITICAL',                        'fieldId'   : '',                        'ruleId'    : $ruleId,                        'path'      : ''                    }                "/>				</xsl:catch>			</xsl:try>		</xsl:variable>		<xsl:variable name="has-error" select="exists($result)"/>		<xsl:variable name="results" as="map(*)*" select="util:as-maps($result)"/>				<xsl:if test="$has-error">							<xsl:choose>				<xsl:when test="not(empty($results))">					<!-- minden találat -->					<xsl:for-each select="$results">						<xsl:call-template name="error-writer">							<xsl:with-param name="errorMap" select="."/>						</xsl:call-template>					</xsl:for-each>				</xsl:when>				<xsl:otherwise>					<UnexpectedType>						<xsl:value-of select="serialize($result, map{'method':'adaptive'})"/>					</UnexpectedType>				</xsl:otherwise>			</xsl:choose>					</xsl:if>	</xsl:template>	<!-- run rule block -->	<xsl:template name="run-rule-block">		<xsl:param name="elements" as="element(Elem)*" required="yes"/>		<xsl:param name="ruleType" as="xs:string" required="yes"/>		<xsl:param name="context" as="node()" required="yes"/>		<xsl:for-each select="$elements">			<xsl:variable name="rules" select="Rules/Rule[RuleType = $ruleType]"/>			<xsl:if test="$rules">				<xsl:iterate select="$rules">					<xsl:call-template name="run-rule-check">						<xsl:with-param name="raw" select="Xpath"/>						<xsl:with-param name="ruleId" select="string(@ruleId)"/>						<xsl:with-param name="context" select="$context"/>					</xsl:call-template>				</xsl:iterate>			</xsl:if>		</xsl:for-each>	</xsl:template>	<!-- FieldCheck -->	<xsl:template name="run-field-check">		<xsl:param name="elements" as="element(Elem)*" required="yes"/>		<xsl:param name="ruleType" as="xs:string" required="yes"/>		<xsl:param name="context" as="node()" required="yes"/>		<xsl:for-each select="$elements">			<xsl:variable name="rules" select="Rules/Rule[RuleType = $ruleType]"/>			<xsl:if test="$rules">				<xsl:iterate select="$rules">					<xsl:param name="errorPaths" select="map{}"/>					<xsl:variable name="raw" select="Xpath"/>					<xsl:variable name="expr" select="replace(string($raw), '^\s+|\s+$', '')"/>					<xsl:variable name="result" as="item()*">						<xsl:try>							<xsl:evaluate xpath="$expr" context-item="$context"/>							<xsl:catch>								<xsl:sequence select="									map{									  'errorCode' : 'EVAL_ERROR',									  'message'   : concat('Hibás XPath: ', $expr),									  'severity'  : 'CRITICAL',									  'fieldId'   : '',									  'ruleId'    : string(@ruleId),									  'path'      : ''									}"/>							</xsl:catch>						</xsl:try>					</xsl:variable>					<xsl:variable name="has-error" select="exists($result)"/>					<xsl:variable name="results" as="map(*)*" select="util:as-maps($result)"/>					<xsl:if test="$has-error">												<xsl:choose>							<xsl:when test="not(empty($results))">								<xsl:for-each select="$results">									<xsl:variable name="resultItem" select="."/>									<xsl:variable name="key" select="normalize-space(string($resultItem?path))"/>									<xsl:choose>										<!-- csak az első előfordulás -->										<xsl:when test="($key eq '') or ($key ne '' and not(map:contains($errorPaths, $key)))">											<xsl:call-template name="error-writer">												<xsl:with-param name="errorMap" select="$resultItem"/>											</xsl:call-template>										</xsl:when>									</xsl:choose>								</xsl:for-each>							</xsl:when>							<xsl:otherwise>								<UnexpectedType>									<xsl:value-of select="serialize($result, map{'method':'adaptive'})"/>								</UnexpectedType>							</xsl:otherwise>						</xsl:choose>					</xsl:if>					<!-- Akkumulátor frissítése fold-left-tel (csak FIELD esetén szükséges) -->					<xsl:variable name="updatedErrorPaths" as="map(xs:string, map(*))">						<xsl:choose>							<xsl:when test="$has-error">								<xsl:variable name="pathsMap" as="map(xs:string, map(*))" select="								  fold-left(									$results,									map{},									function($acc, $m) {									  let $p := normalize-space(string($m?path))									  return										if ($p = '') then										  $acc										else if (map:contains($acc, $p)) then										  $acc										else										  map:put($acc, $p, $m)									}								  )"/>								<xsl:sequence select="map:merge(($errorPaths, $pathsMap), map{'duplicates':'use-first'})"/>							</xsl:when>							<xsl:otherwise>								<xsl:sequence select="$errorPaths"/>							</xsl:otherwise>						</xsl:choose>					</xsl:variable>					<xsl:next-iteration>						<xsl:with-param name="errorPaths" select="$updatedErrorPaths"/>					</xsl:next-iteration>				</xsl:iterate>			</xsl:if>		</xsl:for-each>	</xsl:template>	<!-- Validáció-->	<xsl:template match="/">		<xsl:variable name="main-context" select="/"/>		<xsl:document>			<hibalista:Hibalista xmlns:hibalista="https://soap.api.nav.gov.hu/external/webnyk/webhibalista/1.0">				<BizonylatEllenorzes>					<Bizonylatresz formId="{$form-xml-tag-name}" elemindex="1">						<Hibak>							<!-- FieldCheck-->							<xsl:call-template name="run-field-check">								<xsl:with-param name="elements" select="$elements[@type = $type-field]"/>								<xsl:with-param name="ruleType" select="$event-check"/>								<xsl:with-param name="context" select="$main-context"/>							</xsl:call-template>							<!-- FormCheck -->							<xsl:call-template name="run-rule-block">								<xsl:with-param name="elements" select="$elements[@type = $type-form]"/>								<xsl:with-param name="ruleType" select="$event-check"/>								<xsl:with-param name="context" select="$main-context"/>							</xsl:call-template>							<!-- CalculatedValueCheck -->							<xsl:call-template name="run-rule-block">								<xsl:with-param name="elements" select="$elements[@type = $type-field]"/>								<xsl:with-param name="ruleType" select="$event-valuecalc-check"/>								<xsl:with-param name="context" select="$main-context"/>							</xsl:call-template>						</Hibak>					</Bizonylatresz>				</BizonylatEllenorzes>			</hibalista:Hibalista>		</xsl:document>	</xsl:template></xsl:stylesheet>